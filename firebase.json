{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/propiedad/**",
        "destination": "/index.html"
      }
    ],
    "redirects": [
      {
        "source": "/**",
        "destination": "https://icdeinmobiliaria.com/:splat",
        "type": 301
      }
    ]
  }
}
